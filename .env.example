# ===== 复制本文件为 .env 后按需修改 =====

# 服务监听
APP_HOST=0.0.0.0
APP_PORT=3000

# 运行环境：development | production
APP_ENV=development

# 日志级别（tracing env-filter 语法）：release 用 info,debug
RUST_LOG=kugou_web_api=debug,tower_http=info,sqlx=warn

# SQLite 数据库（文件型，自动在仓库根 data/ 下创建）
DATABASE_URL=sqlite://data/app.db?mode=rwc

# 上游酷狗 API 网关（代理目标）
KUGOU_GATEWAY_URL=https://gateway.kugou.com
# 请求超时（秒）
HTTP_TIMEOUT_SECS=10

# ===== 仅离线/受限网络环境用 =====
# utoipa-swagger-ui 的 build.rs 需从 GitHub 下载 Swagger UI 静态资源。
# 正常联网环境无需设置；若网络访问 github 受限，可指向本地缓存的 zip：
#   SWAGGER_UI_DOWNLOAD_URL=file:///D:/AllCode/rust/kugou_web_api/.swagger-cache/v5.17.14.zip
# （注意 Windows 下用正斜杠 + 盘符大写）
